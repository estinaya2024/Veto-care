se en charge locale\",\n      description: \"Bas‚îú‚åês ‚îú√° B‚îú‚åêja‚îú¬ªa, nous assurons des soins personnalis‚îú‚åês et de proximit‚îú‚åê, b‚îú√≥tissant une relation de confiance durable avec nos patients du quartier.\"\n    },\n    {\n      title: \"Urgences & Suivi\",\n      description: \"Notre ‚îú‚åêquipe est pr‚îú‚åêpar‚îú‚åêe pour la gestion de toute pathologie, garantissant ‚îú√° la fois un r‚îú‚åêtablissement optimal et un suivi digitalis‚îú‚åê (carnet de sant‚îú‚åê).\"\n    }\n  ];\n\n  return (\n    <section className=\"px-8 md:px-16 py-24 bg-white relative overflow-hidden border-t border-gray-50\">\n      <div className=\"max-w-7xl mx-auto relative z-10\">\n        <div className=\"text-center mb-20\">\n          <h2 className=\"text-4xl md:text-5xl font-bold tracking-tight\">\n            Pourquoi nous choisir ?\n          </h2>\n          <p className=\"text-gray-400 font-bold uppercase tracking-widest text-xs mt-4\">L'excellence au service de vos compagnons</p>\n        </div>\n\n        <div className=\"grid md:grid-cols-2 gap-x-20 gap-y-12\">\n          {reasons.map((reason, idx) => (\n            <div key={idx} className=\"flex gap-6 group\">\n              <div className=\"shrink-0\">\n                <div className=\"w-14 h-14 bg-gray-50 rounded-2xl flex items-center justify-center transition-all group-hover:bg-veto-yellow group-hover:shadow-lg group-hover:shadow-veto-yellow/10\">\n                  <PawPrint className=\"text-black\" size={24} strokeWidth={2} />\n                </div>\n              </div>\n              <div className=\"space-y-2\">\n                <h3 className=\"font-bold text-lg text-black uppercase tracking-tight\">\n                  {reason.title}\n                </h3>\n                <p className=\"text-gray-500 font-medium leading-relaxed max-w-md text-sm md:text-base\">\n                  {reason.description}\n                </p>\n              </div>\n            </div>\n          ))}\n        </div>\n      </div>\n    </section>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\components\\ui\\Button.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\components\\ui\\Heading.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\components\\ui\\Skeleton.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\context\\AuthContext.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\context\\AuthProvider.tsx","messages":[{"ruleId":"react-refresh/only-export-components","severity":2,"message":"Fast refresh only works when a file only exports components. Use a new file to share constants or functions between components.","line":52,"column":10,"nodeType":"Identifier","messageId":"namedExport","endLine":52,"endColumn":17}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useEffect, useState } from 'react';\r\nimport { type User, type Session } from '@supabase/supabase-js';\r\nimport { supabase } from '../lib/supabase';\r\nimport { AuthContext } from './AuthContext';\r\n\r\nexport function AuthProvider({ children }: { children: React.ReactNode }) {\r\n  const [user, setUser] = useState<User | null>(null);\r\n  const [session, setSession] = useState<Session | null>(null);\r\n  const [loading, setLoading] = useState(true);\r\n\r\n  useEffect(() => {\r\n    // Get initial session\r\n    supabase.auth.getSession().then(({ data: { session: initialSession } }) => {\r\n      setSession(initialSession);\r\n      setUser(initialSession?.user ?? null);\r\n      setLoading(false);\r\n    });\r\n\r\n    // Listen for auth changes\r\n    const { data: { subscription } } = supabase.auth.onAuthStateChange((_event, newSession) => {\r\n      setSession(newSession);\r\n      setUser(newSession?.user ?? null);\r\n      setLoading(false);\r\n    });\r\n\r\n    return () => {\r\n      subscription.unsubscribe();\r\n    };\r\n  }, []);\r\n\r\n  const signOut = async () => {\r\n    await supabase.auth.signOut();\r\n  };\r\n\r\n  const value = {\r\n    user,\r\n    session,\r\n    role: user?.email === 'a_karou@estin.dz' \r\n      ? 'vet' \r\n      : (user?.user_metadata?.role as 'owner' | 'vet') || 'owner',\r\n    loading,\r\n    signOut,\r\n  };\r\n\r\n  return (\r\n    <AuthContext.Provider value={value}>\r\n      {!loading && children}\r\n    </AuthContext.Provider>\r\n  );\r\n}\r\n\r\nexport { useAuth } from '../hooks/useAuth';\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\hooks\\useAuth.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\lib\\api.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\lib\\supabase.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\lib\\utils.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\lib\\validations.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\main.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\pages\\About.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\pages\\Dashboard.tsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\pages\\Dashboard.tsx:22:7\n  20 |   useEffect(() => {\n  21 |     if (role === 'vet' && activeTab === 'dashboard') {\n> 22 |       setActiveTab('vet');\n     |       ^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  23 |     }\n  24 |     if (role === 'owner' && activeTab === 'vet') {\n  25 |       setActiveTab('dashboard');","line":22,"column":7,"nodeType":null,"endLine":22,"endColumn":19}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport { OwnerDashboard } from '../components/dashboard/OwnerDashboard';\r\nimport { VetDashboard } from '../components/dashboard/VetDashboard';\r\nimport { Settings } from '../components/dashboard/Settings';\r\nimport { useNavigate } from 'react-router-dom';\r\nimport { useAuth } from '../hooks/useAuth';\r\nimport { Sidebar } from '../components/layout/Sidebar';\r\n\r\n\r\ntype DashboardTab = 'dashboard' | 'owner' | 'vet' | 'appointments' | 'settings';\r\n\r\nexport function Dashboard() {\r\n  const { signOut, role } = useAuth();\r\n  const navigate = useNavigate();\r\n  \r\n  // Use a derived initial state to avoid useEffect + setState\r\n  const [activeTab, setActiveTab] = useState<DashboardTab>(role === 'vet' ? 'vet' : 'dashboard');\r\n\r\n  // Synchronize tab if role arrives later (async)\r\n  useEffect(() => {\r\n    if (role === 'vet' && activeTab === 'dashboard') {\r\n      setActiveTab('vet');\r\n    }\r\n    if (role === 'owner' && activeTab === 'vet') {\r\n      setActiveTab('dashboard');\r\n    }\r\n  }, [role, activeTab]);\r\n\r\n  const handleLogout = async () => {\r\n    await signOut();\r\n    navigate('/login');\r\n  };\r\n\r\n  return (\r\n    <div className=\"flex flex-col md:flex-row min-h-screen bg-veto-blue-gray\">\r\n      <Sidebar \r\n        role={role} \r\n        onLogout={handleLogout} \r\n        activeTab={activeTab} \r\n        setActiveTab={setActiveTab} \r\n      />\r\n\r\n      <main className=\"flex-1 p-4 md:p-12 lg:p-16 overflow-y-auto h-screen\">\r\n        <div className=\"max-w-6xl mx-auto\">\r\n          {activeTab === 'dashboard' && <OwnerDashboard />}\r\n          {activeTab === 'owner' && <OwnerDashboard />}\r\n          {activeTab === 'vet' && <VetDashboard />}\r\n          {activeTab === 'settings' && <Settings />}\r\n        </div>\r\n      </main>\r\n\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\src\\pages\\Login.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'Heading' is defined but never used.","line":3,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":3,"endColumn":17,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Heading"},"fix":{"range":[97,150],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport { Button } from '../components/ui/Button';\r\nimport { Heading } from '../components/ui/Heading';\r\nimport { ArrowLeft } from 'lucide-react';\r\nimport { useNavigate } from 'react-router-dom';\r\nimport { useAuth } from '../hooks/useAuth';\r\nimport { supabase } from '../lib/supabase';\r\nimport logo from '../assets/images/logo-icon-only.png';\r\n\r\nexport function Login() {\r\n  const [mode, setMode] = useState<'login' | 'signup'>('login');\r\n  const [email, setEmail] = useState('');\r\n  const [password, setPassword] = useState('');\r\n  const [fullName, setFullName] = useState('');\r\n  const [error, setError] = useState<string | null>(null);\r\n  const [loading, setLoading] = useState(false);\r\n  const { user } = useAuth();\r\n  const navigate = useNavigate();\r\n\r\n  useEffect(() => {\r\n    if (user) {\r\n      navigate('/');\r\n    }\r\n  }, [user, navigate]);\r\n\r\n  const handleAuth = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    setError(null);\r\n    setLoading(true);\r\n\r\n    try {\r\n      if (mode === 'signup') {\r\n        const { error: signupError } = await supabase.auth.signUp({\r\n          email,\r\n          password,\r\n          options: {\r\n            data: {\r\n              full_name: fullName\r\n            }\r\n          }\r\n        });\r\n        if (signupError) throw signupError;\r\n\r\n        // Note: Le profil dans 'maitres' est cr‚îú‚åê‚îú‚åê automatiquement par le trigger SQL\r\n      } else {\r\n        const { error: loginError } = await supabase.auth.signInWithPassword({\r\n          email,\r\n          password,\r\n        });\r\n        if (loginError) throw loginError;\r\n      }\r\n\r\n      navigate('/');\r\n    } catch (err) {\r\n      const message = err instanceof Error ? err.message : 'Une erreur est survenue';\r\n      setError(message);\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"min-h-screen flex flex-col items-center justify-center p-8 bg-[#f8fafc]\">\r\n      <div className=\"bg-white p-12 rounded-3xl shadow-sm border border-gray-100 max-w-md w-full text-center relative\">\r\n        <button\r\n          onClick={() => navigate('/')}\r\n          className=\"absolute top-6 left-6 p-2.5 bg-gray-50 text-black rounded-xl hover:bg-veto-yellow transition-all border border-gray-100\"\r\n          title=\"Retourner ‚îú√° l'accueil\"\r\n        >\r\n          <ArrowLeft size={18} />\r\n        </button>\r\n        \r\n        <div className=\"flex flex-col items-center justify-center mb-10\">\r\n          <img src={logo} alt=\"VetoCare Logo\" className=\"h-16 w-auto object-contain mb-3\" />\r\n          <span className=\"font-heading font-bold text-3xl tracking-tighter uppercase text-black\">VETOCARE</span>\r\n        </div>\r\n\r\n        <h2 className=\"text-2xl font-bold tracking-tight mb-2\">\r\n          {mode === 'login' ? 'Bon retour !' : 'Cr‚îú‚åêer un compte'}\r\n        </h2>\r\n        <p className=\"text-gray-400 font-bold text-sm mb-10\">\r\n          {mode === 'login' ? 'Veuillez vous connecter ‚îú√° votre espace.' : 'Rejoignez la Clinique Veto-Care.'}\r\n        </p>\r\n\r\n        {error && (\r\n          <div className=\"bg-red-50 text-red-600 p-4 rounded-xl mb-6 text-xs font-bold\">\r\n            {error}\r\n          </div>\r\n        )}\r\n\r\n        <form onSubmit={handleAuth} className=\"space-y-6\">\r\n          {mode === 'signup' && (\r\n            <div className=\"text-left space-y-2\">\r\n              <label className=\"text-[10px] font-bold ml-1 uppercase tracking-widest text-gray-400\">Nom complet</label>\r\n              <input\r\n                type=\"text\"\r\n                value={fullName}\r\n                onChange={(e) => setFullName(e.target.value)}\r\n                placeholder=\"Jean Dupont\"\r\n                className=\"w-full px-5 py-3 bg-gray-50 rounded-xl border border-gray-100 focus:ring-2 focus:ring-veto-yellow/20 outline-none transition-all font-bold text-sm\"\r\n                required\r\n              />\r\n            </div>\r\n          )}\r\n\r\n          <div className=\"text-left space-y-2\">\r\n            <label className=\"text-[10px] font-bold ml-1 uppercase tracking-widest text-gray-400\">Email</label>\r\n            <input\r\n              type=\"email\"\r\n              value={email}\r\n              onChange={(e) => setEmail(e.target.value)}\r\n              placeholder=\"votre@email.com\"\r\n              className=\"w-full px-5 py-3 bg-gray-50 rounded-xl border border-gray-100 focus:ring-2 focus:ring-veto-yellow/20 outline-none transition-all font-bold text-sm\"\r\n              required\r\n            />\r\n          </div>\r\n\r\n          <div className=\"text-left space-y-2\">\r\n            <label className=\"text-[10px] font-bold ml-1 uppercase tracking-widest text-gray-400\">Mot de passe</label>\r\n            <input\r\n              type=\"password\"\r\n              value={password}\r\n              onChange={(e) => setPassword(e.target.value)}\r\n              placeholder=\"Œì√á√≥Œì√á√≥Œì√á√≥Œì√á√≥Œì√á√≥Œì√á√≥Œì√á√≥Œì√á√≥\"\r\n              className=\"w-full px-5 py-3 bg-gray-50 rounded-xl border border-gray-100 focus:ring-2 focus:ring-veto-yellow/20 outline-none transition-all font-bold text-sm\"\r\n              required\r\n            />\r\n          </div>\r\n\r\n          <Button type=\"submit\" className=\"w-full py-4 text-sm font-bold rounded-xl\" variant=\"yellow\" disabled={loading}>\r\n            {loading ? 'Chargement...' : mode === 'login' ? 'Se connecter' : \"S'inscrire\"}\r\n          </Button>\r\n\r\n          <div className=\"relative my-8\">\r\n            <div className=\"absolute inset-0 flex items-center\">\r\n              <div className=\"w-full border-t border-gray-100\"></div>\r\n            </div>\r\n            <div className=\"relative flex justify-center text-[10px] uppercase tracking-widest font-bold\">\r\n              <span className=\"bg-white px-2 text-gray-400\">Ou continuer avec</span>\r\n            </div>\r\n          </div>\r\n\r\n          <button\r\n            type=\"button\"\r\n            onClick={async () => {\r\n              const { error } = await supabase.auth.signInWithOAuth({\r\n                provider: 'google',\r\n                options: {\r\n                  redirectTo: window.location.origin + '/'\r\n                }\r\n              });\r\n              if (error) setError(error.message);\r\n            }}\r\n            className=\"w-full flex items-center justify-center gap-3 px-6 py-4 bg-white border border-gray-100 rounded-xl hover:bg-gray-50 transition-all font-bold text-sm\"\r\n          >\r\n            <img src=\"https://www.google.com/favicon.ico\" alt=\"Google\" className=\"w-4 h-4\" />\r\n            Google\r\n          </button>\r\n\r\n          <button\r\n            type=\"button\"\r\n            onClick={() => setMode(mode === 'login' ? 'signup' : 'login')}\r\n            className=\"text-gray-400 text-xs font-bold hover:text-black transition-colors uppercase tracking-widest\"\r\n          >\r\n            {mode === 'login' ? \"Pas encore de compte ? S'inscrire\" : 'D‚îú‚åêj‚îú√° un compte ? Se connecter'}\r\n          </button>\r\n        </form>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\test-api.mjs","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ayaka\\Clinique V‚îú‚åêt‚îú‚åêrinaire\\vite.config.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]}]
