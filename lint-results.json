ick={() => window.location.href = '/'}>\n            <img src={logo} alt=\"VetoCare Logo\" className=\"h-12 w-auto object-contain transition-transform group-hover:scale-105\" />\n            <span className=\"font-heading font-bold text-3xl tracking-tighter uppercase ml-2 text-black\">VETOCARE</span>\n          </div>\n          <p className=\"text-gray-500 font-bold text-sm leading-snug max-w-sm\">\n            Services Professionnels de Soins pour Animaux <br />\n            B‚îú‚åêja‚îú¬ªa, Alg‚îú‚åêrie\n          </p>\n          <div className=\"flex gap-3\">\n            <a href=\"#\" className=\"w-10 h-10 rounded-xl bg-white text-black flex items-center justify-center hover:bg-veto-yellow transition-all shadow-sm border border-gray-100\">\n              <Instagram size={18} />\n            </a>\n            <a href=\"#\" className=\"w-10 h-10 rounded-xl bg-white text-black flex items-center justify-center hover:bg-veto-yellow transition-all shadow-sm border border-gray-100\">\n              <Facebook size={18} />\n            </a>\n          </div>\n        </div>\n\n        {/* Middle: Navigation */}\n        <div className=\"md:col-span-3 flex flex-col items-center md:items-start gap-6 mt-4 md:mt-0 text-center md:text-left\">\n          <h4 className=\"font-bold text-xs tracking-[0.2em] uppercase text-gray-400\">Navigation</h4>\n          <ul className=\"flex flex-col gap-3 font-bold text-sm text-gray-500\">\n            <li><a href=\"/#services\" className=\"hover:text-black transition-colors\">Services</a></li>\n            <li><a href=\"/about\" className=\"hover:text-black transition-colors\">‚îú√á Propos</a></li>\n            <li><a href=\"#contact\" className=\"hover:text-black transition-colors\">Contact</a></li>\n          </ul>\n        </div>\n\n        {/* Right: CTA & Contacts */}\n        <div className=\"md:col-span-5 flex flex-col gap-4 items-center md:items-end text-center md:text-right mt-4 md:mt-0\">\n          <h2 className=\"text-2xl md:t